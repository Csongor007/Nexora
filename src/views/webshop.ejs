          const termekDiv = document.createElement("div");

          // Láthatatlan ID és class a típushoz
          termekDiv.className = `termek ${termek.tipus}`;
          termekDiv.id = termek.tipus;

          const img = new Image();
          img.src = `/img/termekek/${termek.kep}`;
          img.alt = termek.kep.replace(".jpg", "").replace(".png", ""); // Felirat csak a név
