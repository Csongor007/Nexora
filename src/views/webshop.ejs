<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400..900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/transition.css" />
    <link rel="stylesheet" href="/css/index.css" />
    <link rel="stylesheet" href="/css/webshop.css" />
    <link rel="stylesheet" href="/css/cart.css" />
    <link rel="icon" href="favicon.ico" type="image/x-icon" />
    <link rel="icon" type="image/ico" href="/img/icons/nexora_logo_tp.png" />
    <script src="/js/transitions.js"></script>
    <title>Webshop</title>

    <div class="box">
      <div class="wave -one"></div>
      <div class="wave -two"></div>
      <div class="wave -three"></div>
    </div>
  </head>
  <body>
    <div id="particle-background"></div>
    <div class="transition transition-1 is-active"></div>
    <header>
      <button class="menu-toggle">☰</button>
      <nav class="left">
        <ul class="nav-menu">
          <li>
            <a href="/webshop" title="Webshop"><img src="/img/icons/bags-shopping.webp" alt="Webshop" /></a>
          </li>
          <li>
            <a href="/aszf" title="ÁSZF"><img src="/img/icons/terms-info.webp" alt="ÁSZF" /></a>
          </li>
        </ul>
      </nav>
      <div class="logo">
        <a href="/" title="Főoldal"><img src="/img/icons/nexora_logo_tp.webp" alt="Logo" /></a>
      </div>
      <nav class="right">
        <ul class="nav-menu2">
          <li>
            <a href="/kontakt" title="Elérhetőségek"><img src="/img/icons/clip-mail.webp" alt="Elérhetőségek" /></a>
          </li>
          <li>
            <a href="#" title="Bejelentkezés"
              ><img src="/img/icons/profile.webp" alt="Bejelentkezés" class="floating-btn" id="floatingBtn"
            /></a>
          </li>
        </ul>
      </nav>
    </header>
    <main style="display: flex; align-items: flex-start">
      <div class="filters">
        <h1
          style="
            font-size: 30px;
            margin-bottom: 0px;
            font-family: Orbitron, sans-serif;
            color: white;
            font-weight: bolder;
            justify-self: left;
            position: relative;
          ">
          Keresés:
        </h1>
        <input type="text" id="search" onkeyup="filterSearch()" placeholder="Keresés..." class="search" />

        <h1
          style="
            font-size: 30px;
            margin-bottom: 0px;
            font-family: Orbitron, sans-serif;
            color: white;
            font-weight: bolder;
            justify-self: left;
            position: relative;
            top: 10px;
          ">
          Szűrők:
        </h1>

        <h2
          style="
            margin-bottom: 0px;
            font-family: Orbitron, sans-serif;
            color: white;
            font-weight: bolder;
            justify-self: left;
            position: relative;
            top: 10px;
          ">
          Márka:
        </h2>

        <button style="position: relative; top: -80px; left: 165px" onclick="filterByCategory('termek'), document.getElementById('search').value = ''" class="tags">
          Összes
        </button>

        <div class="marka-gombok">
          <button onclick="filterByCategory('microsoft')" class="tags brands">Microsoft</button>
          <button onclick="filterByCategory('linux')" class="tags brands">Linux</button>
          <button onclick="filterByCategory('avg')" class="tags brands">AVG</button>
        </div>

        <h2
          style="
            margin-bottom: 1rem;
            margin-top: 1.5rem;
            font-family: Orbitron, sans-serif;
            color: white;
            font-weight: bolder;
            position: relative;
          ">
          Osztály:
        </h2>

        <div class="osztalyok">
          <button onclick="filterByCategory('szoftver')" class="tags class">Szoftver</button>
          <button onclick="filterByCategory('license')" class="tags class">Licensz</button>
          <button onclick="filterByCategory('jatek')" class="tags class">Játékok</button>
          <button onclick="filterByCategory('giftcard')" class="tags class">Ajándékkártyák</button>
        </div>
      </div>

      <div class="keret" id="keret"></div>

      <script>
const keret = document.getElementById("keret");

// Dinamikus stílus a termékekhez és gombokhoz
const style = document.createElement("style");
style.textContent = `
  #keret { display:flex; flex-wrap:wrap; gap:20px; justify-content:left; max-width:fit-content; }
  .termek { width:300px; padding:10px; border-radius:20px; text-align:center; box-shadow:0 0 10px rgba(0,0,0,0.1); background:inherit; background-color: rgba(51, 51, 51, 0.5); backdrop-filter: blur(6px); }
  .hover-anim { transition: all 0.2s ease; }
  .hover-anim:hover { transform: scale(1.05); }
`;
document.head.appendChild(style);

// JSON betöltése
fetch("img/termekbazis/termek.json")
  .then(res => {
    if (!res.ok) throw new Error("Nem sikerült betölteni a JSON fájlt");
    return res.json();
  })
  .then(termekek => {
    termekek.forEach(termek => {
      const termekDiv = document.createElement("div");
      termekDiv.className = `termek ${termek.kategoria}`;

      const img = new Image();
      img.src = `/img/termekek/${termek.kepformatum}`;
      img.alt = termek.nev;
      img.style = `
        width: 280px;
        height: 280px;
        object-fit: contain;
        display: block;
        margin: 0 auto;
      `;

      img.onerror = () => console.error(`Kép nem található: ${termek.kepformatum}`);

      img.onload = () => {
        termekDiv.innerHTML = `
          ${img.outerHTML}
          <div style="display:flow; align-items:center; gap:5px; justify-content:center; width:100%; text-align:center; margin:5px 0; position:fixed;">
            <p class="nev" style="font-weight:bold; margin:0;">${termek.nev}</p>
            <p style="font-weight:bold; color:#2ead2e; margin:0;">${termek.ar.toLocaleString()} Ft</p>
          </div>
          <div style="display:flex; justify-content:center; gap:15px; margin-top:75px;">
            <button class="hover-anim kosar-gomb" style="font-family:Orbitron,sans-serif; font-weight:bolder; width:150px; height:45px; background-color:rgba(46,173,46); border:none; border-radius:10px; cursor:pointer;">Kosárba🛒</button>
            <button class="hover-anim info-gomb" style="font-family:Orbitron,sans-serif; font-weight:bolder; width:150px; height:45px; background-color:rgba(46,173,46); border:none; border-radius:10px; cursor:pointer;">Termék Információℹ️</button>
          </div>
        `;

        // Kosár gomb - JAVÍTOTT VERZIÓ
        termekDiv.querySelector(".kosar-gomb").addEventListener("click", (e) => {
          const button = e.target;
          const termekData = {
            nev: termek.nev,
            ar: termek.ar,
            kategoria: termek.kategoria,
            kep: termek.kepformatum
          };
          
          // addToCart függvény a cart.js-ből
          addToCart(button, termekData);
        });

        // Termék info gomb – felugró modal
        termekDiv.querySelector(".info-gomb").addEventListener("click", () => {
          const overlay = document.createElement("div");
          overlay.style.position = "fixed";
          overlay.style.top = "0";
          overlay.style.left = "0";
          overlay.style.width = "100%";
          overlay.style.height = "100%";
          overlay.style.background = "rgba(0,0,0,0.5)";
          overlay.style.backdropFilter = "blur(6px)";
          overlay.style.display = "flex";
          overlay.style.justifyContent = "center";
          overlay.style.alignItems = "center";
          overlay.style.zIndex = "1000";

          const modal = document.createElement("div");
          modal.style.background = "rgba(51, 51, 51, 0.5)";
          modal.style.backdropFilter = "blur(6px)";
          modal.style.padding = "20px";
          modal.style.borderRadius = "20px";
          modal.style.borderColor = "rgb(46, 173, 46)";
          modal.style.borderStyle = "solid";
          modal.style.borderWidth = "5px";
          modal.style.maxWidth = "400px";
          modal.style.width = "90%";
          modal.style.textAlign = "center";
          modal.style.position = "relative";
          modal.innerHTML = `
            <button style="
              position:absolute;
              top:10px;
              right:10px;
              background:#2ead2e;
              border:none;
              border-radius:5px;
              color:white;
              font-weight:bold;
              padding:5px 10px;
              cursor:pointer;
            ">✖</button>
            <h2 style="margin-bottom:10px; color: #ccc;">${termek.nev}</h2>
            <p style="font-weight:bold; color:#2ead2e;">Kategória: ${termek.kategoria}</p>
            <p style="font-weight:bold;">Ár: ${termek.ar.toLocaleString()} Ft</p>
            <p style="margin-top:10px;">${termek.info ? termek.info.replaceAll(".",".<br>") : 'Nincs további információ.'}</p>
          `;

          modal.querySelector("button").addEventListener("click", () => {
            document.body.removeChild(overlay);
          });

          overlay.appendChild(modal);
          document.body.appendChild(overlay);
        });

        keret.appendChild(termekDiv);
      };
    });
  })
  .catch(err => console.error("Hiba a JSON betöltése közben:", err));
</script>


      <div class="popup-overlay" id="popupOverlay">
        <div class="popup" id="popupContent"></div>
      </div>
      <div style="height: 100px"></div>
    </main>

    <div class="visszanyil" id="Visszanyil" style="z-index: 10;">▲</div>

    <footer>
      <p>&copy; <span id="year"></span> Nexora. All rights reserved.</p>

      <script>
        document.getElementById("year").textContent = new Date().getFullYear();
      </script>
    </footer>

    <script src="https://d3js.org/d3.v3.min.js"></script>
    <script>
      // Ez az egyetlen blokk, ami marad, mert a backend-ről jön az adat
      window.loggedInUser = <%- user ? JSON.stringify(user) : 'null' %>;
    </script>
    <script src="/js/ui-effects.js"></script>
    <script src="/js/filters.js"></script>
    <script src="/js/auth-popup.js"></script>
    <script src="/js/cart.js"></script>
  </body>
  
</html>
