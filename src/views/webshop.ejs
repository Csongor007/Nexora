    <script>
      let lastScrollTop = 0;
      window.addEventListener("scroll", () => {
        const header = document.querySelector("header");
        const currentScroll = window.pageYOffset || document.documentElement.scrollTop;

        if (currentScroll > lastScrollTop) {
          header.classList.add("hidden");
        } else {
          header.classList.remove("hidden");
        }

        lastScrollTop = currentScroll <= 0 ? 0 : currentScroll;
      });
      
      function filterByCategory(category) {
        const kategoriaszuro = document.querySelectorAll(".termek");

        kategoriaszuro.forEach((kategoriaszuroElem) => {
          if (category === "all" || kategoriaszuroElem.classList.contains(category)) {
            kategoriaszuroElem.style.display = "block";
          } else {
            kategoriaszuroElem.style.display = "none";
          }
        });
      }

      function filterSearch() {
        const searchQuery = document.getElementById("search").value.toLowerCase();
        const keresoszuro = document.querySelectorAll(".termek");

        keresoszuro.forEach((keresoszuroElem) => {
          const termekNev = keresoszuroElem.querySelector(".nev").innerText.toLowerCase();

          if (termekNev.includes(searchQuery)) {
            keresoszuroElem.style.display = "block";
          } else {
            keresoszuroElem.style.display = "none";
          }
        });
      }
    </script>
