      width: 280px;
      height: 280px;
      object-fit: contain;
      background-color: transparent;
      display: block;
      margin: 0 auto;
      padding: 0;
      border: none;
      vertical-align: middle;
      border-radius: 0px;
    `;

          img.onerror = () => {
            console.error(`${termek.kep} kép nem jó!`);
            termekDiv.innerHTML = `<p style="color:red;">${termek.kep} kép nem található!</p>`;
          };

