<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400..900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/transition.css" />
    <link rel="stylesheet" href="/css/index.css" />
    <link rel="stylesheet" href="/css/webshop.css" />
    <script src="/js/transitions.js"></script>
    <title>Webshop</title>

    <div class="box">
      <div class="wave -one"></div>
      <div class="wave -two"></div>
      <div class="wave -three"></div>
    </div>
  </head>
  <body>
    <div id="particle-background"></div>
    <div class="transition transition-1 is-active"></div>
    <header>
      <button class="menu-toggle">☰</button>
      <nav class="left">
        <ul class="nav-menu">
          <li>
            <a href="/webshop" title="Webshop"><img src="/img/icons/bags-shopping.webp" alt="Webshop" /></a>
          </li>
          <li>
            <a href="/aszf" title="ÁSZF"><img src="/img/icons/terms-info.webp" alt="ÁSZF" /></a>
          </li>
        </ul>
      </nav>
      <div class="logo">
        <a href="/" title="Főoldal"><img src="/img/icons/nexora_logo_tp.webp" alt="Logo" /></a>
      </div>
      <nav class="right">
        <ul class="nav-menu2">
          <li>
            <a href="/kontakt" title="Elérhetőségek"><img src="/img/icons/clip-mail.webp" alt="Elérhetőségek" /></a>
          </li>
          <li>
            <a href="#" title="Bejelentkezés"
              ><img src="/img/icons/profile.webp" alt="Bejelentkezés" class="floating-btn" id="floatingBtn"
            /></a>
          </li>
        </ul>
      </nav>
    </header>
    <main style="display: flex; align-items: flex-start">
      <div class="filters">
        <h1
          style="
            font-size: 30px;
            margin-bottom: 0px;
            font-family: Orbitron, sans-serif;
            color: white;
            font-weight: bolder;
            justify-self: left;
            position: relative;
          ">
          Keresés:
        </h1>
        <input type="text" id="search" onkeyup="filterSearch()" placeholder="Keresés..." class="search" />

        <h1
          style="
            font-size: 30px;
            margin-bottom: 0px;
            font-family: Orbitron, sans-serif;
            color: white;
            font-weight: bolder;
            justify-self: left;
            position: relative;
            top: 10px;
          ">
          Szűrők:
        </h1>

        <h2
          style="
            margin-bottom: 0px;
            font-family: Orbitron, sans-serif;
            color: white;
            font-weight: bolder;
            justify-self: left;
            position: relative;
            top: 10px;
          ">
          Márka:
        </h2>

        <button style="position: relative; top: -80px; left: 165px" onclick="filterByCategory('termek')" class="tags">
          Összes
        </button>

        <div class="marka-gombok">
          <button onclick="filterByCategory('microsoft')" class="tags brands">Microsoft</button>
          <button onclick="filterByCategory('linux')" class="tags brands">Linux</button>
          <button onclick="filterByCategory('Szűrő3')" class="tags brands">Szűrő3</button>
        </div>

        <h2
          style="
            margin-bottom: 1rem;
            margin-top: 1.5rem;
            font-family: Orbitron, sans-serif;
            color: white;
            font-weight: bolder;
            position: relative;
          ">
          Osztály:
        </h2>

        <div class="osztalyok">
          <button onclick="filterByCategory('szoftver')" class="tags class">Szoftver</button>
          <button onclick="filterByCategory('operaciosrendszer')" class="tags class">Operációs rendszer</button>
          <button onclick="filterByCategory('licensz')" class="tags class">Licensz</button>
          <button onclick="filterByCategory('szoftver')" class="tags class">Játékok</button>
          <button onclick="filterByCategory('operaciosrendszer')" class="tags class">Feltöltőkátyák</button>
          <button onclick="filterByCategory('licensz')" class="tags class">Ajándékkártyák</button>
        </div>
      </div>

      <div class="keret">
        <div class="termek licensz microsoft szoftver">
          <img src="/img/office.webp" alt="office" class="kepek" />
          <p class="nev">Termék1</p>
          <button
            class="hover-anim"
            style="
              font-family: Orbitron, sans-serif;
              font-weight: bolder;
              background-repeat: no-repeat;
              width: 30%;
              height: 13%;
              background-size: 100%;
              border: none;
              background-color: rgba(46, 173, 46);
              border-radius: 10px;
              position: relative;
              left: -15px;
            ">
            Kosárba🛒
          </button>
          <button
            class="hover-anim"
            style="
              font-family: Orbitron, sans-serif;
              font-weight: bolder;
              background-repeat: no-repeat;
              width: 30%;
              height: 13%;
              background-size: 100%;
              background-color: rgba(46, 173, 46);
              border: none;
              border-radius: 10px;
              position: relative;
              left: -5px;
              top: 7.5px;
            ">
            Termék Információℹ️
          </button>
        </div>
        <div class="termek licensz microsoft operaciosrendszer">
          <img src="/img/windows.webp" alt="windows" class="kepek" />
          <p class="nev">Termék2</p>
          <button
            class="hover-anim"
            style="
              font-family: Orbitron, sans-serif;
              font-weight: bolder;
              background-repeat: no-repeat;
              width: 30%;
              height: 13%;
              background-size: 100%;
              background-color: rgba(46, 173, 46);
              border: none;
              border-radius: 10px;
              position: relative;
              left: -15px;
            ">
            Kosárba🛒
          </button>
          <button
            class="hover-anim"
            style="
              font-family: Orbitron, sans-serif;
              font-weight: bolder;
              background-repeat: no-repeat;
              width: 30%;
              height: 13%;
              background-size: 100%;
              background-color: rgba(46, 173, 46);
              border: none;
              border-radius: 10px;
              position: relative;
              left: -5px;
              top: 7.5px;
            ">
            Termék Információℹ️
          </button>
        </div>
        <div class="termek licensz operaciosrendszer linux">
          <img src="/img/linux.webp" alt="Linux" class="kepek" />
          <p class="nev">Termék3</p>
          <button
            class="hover-anim"
            style="
              font-family: Orbitron, sans-serif;
              font-weight: bolder;
              background-repeat: no-repeat;
              width: 30%;
              height: 13%;
              background-size: 100%;
              background-color: rgba(46, 173, 46);
              border: none;
              border-radius: 10px;
              position: relative;
              left: -15px;
            ">
            Kosárba🛒
          </button>
          <button
            class="hover-anim"
            style="
              font-family: Orbitron, sans-serif;
              font-weight: bolder;
              background-repeat: no-repeat;
              width: 30%;
              height: 13%;
              background-size: 100%;
              background-color: rgba(46, 173, 46);
              border: none;
              border-radius: 10px;
              position: relative;
              left: -5px;
              top: 7.5px;
            ">
            Termék Információℹ️
          </button>
        </div>
      </div>

      <div>👤</div>

      <div class="popup-overlay" id="popupOverlay">
        <div class="popup" id="popupContent"></div>
      </div>
      <div style="height: 100px"></div>
    </main>

    <footer>
      <p>&copy; <span id="year"></span> Nexora. All rights reserved.</p>

      <script>
        document.getElementById("year").textContent = new Date().getFullYear();
      </script>
    </footer>

    <script src="https://d3js.org/d3.v3.min.js"></script>
    <script>
      // Ez az egyetlen blokk, ami marad, mert a backend-ről jön az adat
      window.loggedInUser = <%- user ? JSON.stringify(user) : 'null' %>;
    </script>
    <script src="/js/ui-effects.js"></script>
    <script src="/js/filters.js"></script>
    <script src="/js/auth-popup.js"></script>
  </body>
</html>
