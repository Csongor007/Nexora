<!DOCTYPE html>
<html lang="en">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400..900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/kontakt.css" type="text/css" />

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Nexora Hivatalos Weboldala" />
    <link rel="icon" href="favicon.ico" type="image/x-icon" />
    <link rel="icon" type="image/ico" href="/img/icons/nexora_logo_tp.png" />
    <link rel="stylesheet" href="/css/transition.css" />
    <script src="/js/transitions.js"></script>
    <title>Projekt</title>

    <div class="box">
      <div class="wave -one"></div>
      <div class="wave -two"></div>
      <div class="wave -three"></div>
    </div>

    <div class="background"></div>

    <script src="https://d3js.org/d3.v3.min.js"></script>
    <script src="/js/ui-effects.js" defer></script>
  </head>
  <body>
    <div id="particle-background"></div>

    <div class="transition transition-1 is-active"></div>
    <header>
      <button class="menu-toggle">☰</button>
      <nav class="left">
        <ul class="nav-menu">
          <li>
            <a href="/webshop" title="Webshop"><img src="/img/icons/bags-shopping.webp" alt="Webshop" /></a>
          </li>
          <li>
            <a href="/aszf" title="ÁSZF"><img src="/img/icons/terms-info.webp" alt="ÁSZF" /></a>
          </li>
        </ul>
      </nav>
      <div class="logo">
        <a href="/" title="Főoldal"><img src="/img/icons/nexora_logo_tp.webp" alt="Logo" /></a>
      </div>
      <nav class="right">
        <ul class="nav-menu2">
          <li>
            <a href="/kontakt" title="Elérhetőségek"><img src="/img/icons/clip-mail.webp" alt="Elérhetőségek" /></a>
          </li>
          <li>
            <a href="#" title="Bejelentkezés"
              ><img src="/img/icons/profile.webp" alt="Bejelentkezés" class="floating-btn" id="floatingBtn"
            /></a>
          </li>
        </ul>
      </nav>
    </header>
    <main style="z-index: 1">
      <div class="container">
        <form id="contactForm">
          <label for="name">Név</label>
          <input type="text" id="name" name="name" placeholder="Név..." required />

          <label for="email">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="E-mail címed"
            required
            title="Kérjük, érvényes email címet adj meg (pl. valami@domain.hu)" />

          <label for="subject">Megjegyzés</label>
          <textarea
            id="subject"
            name="subject"
            placeholder="Megosztani kívánt információid (max. 300 karakter)"
            style="height: 200px"
            maxlength="300"
            required></textarea>

          <input type="submit" value="Küldés" />
        </form>
      </div>

      <div style="height: 0px"></div>
    </main>

    <div class="popup-overlay" id="popupOverlay">
      <div class="popup" id="popupContent"></div>
    </div>

    <footer>
      <p>&copy; <span id="year"></span> Nexora. All rights reserved.</p>

      <script>
        document.getElementById("year").textContent = new Date().getFullYear();
      </script>
    </footer>

    <script>
      window.loggedInUser = <%- (typeof user !== 'undefined' && user) ? JSON.stringify(user) : 'null' %>;
    </script>

    <script src="/js/contact-handler.js" defer></script>
    <script src="/js/auth-popup.js" defer></script>
  </body>
</html>
