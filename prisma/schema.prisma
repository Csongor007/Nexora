generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model felhasznalok {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  email       String   @unique @db.VarChar(50)
  jelszo_hash String   @db.Text
  nev         String   @db.VarChar(50)
  letrehozva  DateTime @default(now()) @db.Timestamp(0)
}

model feltoltokartya {
  kartya_id   Int    @id @default(autoincrement()) @db.UnsignedInt
  termek_id   Int    @db.UnsignedInt
  szolgaltato String @db.VarChar(50)
  ertek       Int    @db.UnsignedInt

  @@index([termek_id], map: "FK_feltoltokartya_termekek")
}

model jatekok {
  jatek_id          Int      @id @default(autoincrement()) @db.UnsignedInt
  termek_id         Int      @db.UnsignedInt
  platform          String   @db.VarChar(50)
  mufaj             String   @db.VarChar(50)
  megjelenesi_datum DateTime @db.DateTime(0)

  @@index([termek_id], map: "FK_jatekok_termekek")
}

model kategoriak {
  id  Int    @id @default(autoincrement()) @db.UnsignedInt
  nev String @db.VarChar(50)
}

model rendeles_tetel {
  id          Int     @id @default(autoincrement()) @db.UnsignedInt
  rendeles_id Int     @db.UnsignedInt
  termek_id   Int     @db.UnsignedInt
  mennyiseg   Int     @db.UnsignedInt
  egysegar    Decimal @db.Decimal(10, 2)

  @@index([rendeles_id], map: "FK_rendeles_tetel_rendelesek")
  @@index([termek_id], map: "FK_rendeles_tetel_termekek")
}

model rendelesek {
  id             Int      @id @default(autoincrement()) @db.UnsignedInt
  felhasznalo_id Int      @db.UnsignedInt
  vegosszeg      Decimal  @db.Decimal(10, 2)
  allapot        String   @db.VarChar(50)
  rendelve       DateTime @db.DateTime(0)

  @@index([felhasznalo_id], map: "FK_rendelesek_felhasznalok")
}

model szallitas {
  id           Int    @id @default(autoincrement()) @db.UnsignedInt
  rendeles_id  Int    @db.UnsignedInt
  vezeteknev   String @db.VarChar(50)
  keresztnev   String @db.VarChar(50)
  orszag       String @db.VarChar(50)
  varos        String @db.VarChar(50)
  iranyitoszam String @db.VarChar(50)
  utca         String @db.VarChar(50)
  telefonszam  String @db.VarChar(50)

  @@index([rendeles_id], map: "FK_szallitas_rendelesek")
}

model szoftverek {
  szoftver_id        Int    @id @default(autoincrement()) @db.UnsignedInt
  termek_id          Int    @db.UnsignedInt
  licensz_tipus      String @db.VarChar(50)
  operacios_rendszer String @db.VarChar(50)

  @@index([termek_id], map: "FK_szoftverek_termekek")
}

model termekek {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  nev         String   @db.VarChar(50)
  ar          Decimal  @db.Decimal(10, 2)

  kategoria   String   @db.VarChar(50)

  keszlet     Int      @default(0) @db.UnsignedInt
  kepformatum String   @db.Text
}


model aktivaciokulcsok {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  termek_id Int      @db.UnsignedInt
  kulcs     String   @unique @db.VarChar(255)
  eladva    Boolean  @default(false)
  eladva_at DateTime?

  @@index([termek_id])
}

model kapcsolatfelvetel {
  id     Int    @id @default(autoincrement()) @db.UnsignedInt
  Nev    String @db.VarChar(50)
  Email  String @db.VarChar(50)
  Uzenet String @db.Text
  Kuldve DateTime @default(now()) @db.Timestamp(0)
}

