generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// FELHASZNÁLÓK
model felhasznalok {
  id          Int          @id @default(autoincrement()) @db.UnsignedInt
  email       String       @unique @db.VarChar(50)
  jelszo_hash String       @db.Text
  nev         String       @db.VarChar(50)
  letrehozva  DateTime     @default(now()) @db.Timestamp(0)
  rendelesek  rendelesek[]
}

// KAPCSOLATFELVÉTEL
model kapcsolatfelvetel {
  id     Int      @id @default(autoincrement()) @db.UnsignedInt
  Nev    String   @db.VarChar(50)
  Email  String   @db.VarChar(50)
  Uzenet String   @db.Text
  Kuldve DateTime @default(now()) @db.Timestamp(0)
}

// RENDELÉSEK - Digitális termékekhez
model rendelesek {
  id                 Int                  @id @default(autoincrement()) @db.UnsignedInt
  felhasznalo_id     Int                  @db.UnsignedInt
  felhasznalo        felhasznalok         @relation(fields: [felhasznalo_id], references: [id])
  vegosszeg          Decimal              @db.Decimal(10, 2)
  rendszerhaszn_dij  Decimal              @default(990) @db.Decimal(10, 2)
  fizetesi_mod       String               @db.VarChar(50) // 'card', 'apple_pay', 'google_pay'
  allapot            String               @default("feldolgozas_alatt") @db.VarChar(50)
  rendelve           DateTime             @default(now()) @db.Timestamp(0)
  teljesitve_at      DateTime?            @db.Timestamp(0)
  rendeles_tetel     rendeles_tetel[]
  szamlazasi_adatok  szamlazasi_adatok?

  @@index([felhasznalo_id], map: "FK_rendelesek_felhasznalok")
}

// RENDELÉSI TÉTELEK
model rendeles_tetel {
  id                    Int                     @id @default(autoincrement()) @db.UnsignedInt
  rendeles_id           Int                     @db.UnsignedInt
  rendeles              rendelesek              @relation(fields: [rendeles_id], references: [id])
  termek_nev            String                  @db.VarChar(255)
  termek_kategoria      String                  @db.VarChar(50)
  egysegar              Decimal                 @db.Decimal(10, 2)
  mennyiseg             Int                     @default(1) @db.UnsignedInt
  aktivacios_kulcs      String?                 @db.VarChar(255)
  kulcs_elkuldve        Boolean                 @default(false)
  aktivalt              Boolean                 @default(false)
  aktivalt_at           DateTime?               @db.Timestamp(0)

  @@index([rendeles_id], map: "FK_rendeles_tetel_rendelesek")
}

// SZÁMLÁZÁSI ADATOK
model szamlazasi_adatok {
  id              Int        @id @default(autoincrement()) @db.UnsignedInt
  rendeles_id     Int        @unique @db.UnsignedInt
  rendeles        rendelesek @relation(fields: [rendeles_id], references: [id])
  nev             String     @db.VarChar(100)
  email           String     @db.VarChar(100)
  telefonszam     String     @db.VarChar(20)
  orszag          String     @default("Magyarország") @db.VarChar(50)
  varos           String     @db.VarChar(50)
  iranyitoszam    String     @db.VarChar(10)
  utca_hazszam    String     @db.VarChar(100)

  @@index([rendeles_id], map: "FK_szamlazas_rendelesek")
}
